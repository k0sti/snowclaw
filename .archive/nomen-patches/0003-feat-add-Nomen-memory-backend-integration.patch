+//! Migration from Snowclaw's SQLite memory backend to Nomen.
+//!
+//! Reads existing memories from the local SQLite database (`memories` table)
+//! and ingests them into Nomen as kind 31234 events with v0.2 d-tags.
+//!
+//! Old data is **never deleted** — the migration is additive/copy-only.
+
+use anyhow::{Context, Result};
+use console::style;
+use rusqlite::Connection;
+use std::path::Path;
+
+/// A single memory row read from the legacy SQLite database.
+#[derive(Debug)]
+pub struct LegacyMemory {
+    pub key: String,
+    pub content: String,
+    pub category: String,
+    pub created_at: String,
+    pub session_id: Option<String>,
+}
+
+/// Summary returned after a migration run.
+#[derive(Debug)]
+pub struct MigrationReport {
+    pub total_read: usize,
+    pub migrated: usize,
+    pub skipped: usize,
+    pub errors: Vec<String>,
+}
+
+/// Read all memories from the legacy SQLite database.
+///
+/// Database path: `{workspace_dir}/memory/brain.db` (standard SQLite backend)
+/// or `{workspace_dir}/nostr_sqlite/memory/brain.db` (Nostr+SQLite backend).
+pub fn read_legacy_memories(workspace_dir: &Path) -> Result<Vec<LegacyMemory>> {
+    // Try both possible paths.
+    let candidates = [
+        workspace_dir.join("memory").join("brain.db"),
+        workspace_dir.join("nostr_sqlite").join("memory").join("brain.db"),
+    ];
+
+    let db_path = candidates
+        .iter()
+        .find(|p| p.exists())
+        .ok_or_else(|| {
+            anyhow::anyhow!(
+                "No legacy SQLite database found. Checked:\n  - {}\n  - {}",
+                candidates[0].display(),
+                candidates[1].display()
+            )
+        })?;
+
+    let conn = Connection::open_with_flags(
+        db_path,
+        rusqlite::OpenFlags::SQLITE_OPEN_READ_ONLY | rusqlite::OpenFlags::SQLITE_OPEN_NO_MUTEX,
+    )
+    .with_context(|| format!("Failed to open legacy database: {}", db_path.display()))?;
+
+    // Check if the session_id column exists (added in a migration).
+    let has_session_id = conn
+        .prepare("SELECT sql FROM sqlite_master WHERE type='table' AND name='memories'")
+        .and_then(|mut s| s.query_row([], |row| row.get::<_, String>(0)))
+        .map(|sql| sql.contains("session_id"))
+        .unwrap_or(false);
+
+    let query = if has_session_id {
+        "SELECT key, content, category, created_at, session_id FROM memories ORDER BY created_at ASC"
+    } else {
+        "SELECT key, content, category, created_at, NULL as session_id FROM memories ORDER BY created_at ASC"
+    };
+
+    let mut stmt = conn.prepare(query)?;
+    let rows = stmt
+        .query_map([], |row| {
+            Ok(LegacyMemory {
+                key: row.get(0)?,
+                content: row.get(1)?,
+                category: row.get(2)?,
+                created_at: row.get(3)?,
+                session_id: row.get(4)?,
+            })
+        })?
+        .collect::<Result<Vec<_>, _>>()
+        .context("Failed to read legacy memories")?;
+
+    Ok(rows)
+}
+
+/// Map a legacy category string to a Nomen tier.
+fn category_to_nomen_tier(category: &str) -> &str {
+    match category {
+        "core" | "daily" | "conversation" => "personal",
+        _ => "personal",
+    }
+}
+
+/// Convert a legacy SQLite key into a Nomen-style topic slug.
+///
+/// Strips `snowclaw:` prefixes if present, replaces non-alphanumeric chars
+/// with hyphens, and lowercases.
+fn normalize_topic(key: &str) -> String {
+    let stripped = key
+        .strip_prefix("snowclaw:")
+        .unwrap_or(key);
+
+    // Remove category prefix if present (e.g. "core:user:profile" → "user:profile").
+    let stripped = stripped
+        .strip_prefix("core:")
+        .or_else(|| stripped.strip_prefix("daily:"))
+        .or_else(|| stripped.strip_prefix("conversation:"))
+        .unwrap_or(stripped);
+
+    // Replace colons and whitespace with hyphens, lowercase.
+    stripped
+        .chars()
+        .map(|c| if c.is_alphanumeric() || c == '-' || c == '_' { c.to_ascii_lowercase() } else { '-' })
+        .collect::<String>()
+        .trim_matches('-')
+        .to_string()
+}
+
+/// Run the migration: read from SQLite, ingest into Nomen.
+///
+/// If `dry_run` is true, memories are read and printed but not stored.
+pub async fn migrate(
+    workspace_dir: &Path,
+    dry_run: bool,
+) -> Result<MigrationReport> {
+    let memories = read_legacy_memories(workspace_dir)?;
+
+    println!(
+        "{} Found {} legacy memories to migrate.",
+        style("ℹ").blue().bold(),
+        style(memories.len()).cyan().bold(),
+    );
+
+    if memories.is_empty() {
+        return Ok(MigrationReport {
+            total_read: 0,
+            migrated: 0,
+            skipped: 0,
+            errors: vec![],
+        });
+    }
+
+    if dry_run {
+        println!("\n{} Dry run — no data will be written.\n", style("⚠").yellow().bold());
+        for mem in &memories {
+            let topic = normalize_topic(&mem.key);
+            let tier = category_to_nomen_tier(&mem.category);
+            let preview = mem.content.lines().next().unwrap_or(&mem.content);
+            let preview = if preview.len() > 80 {
+                format!("{}...", &preview[..77])
+            } else {
+                preview.to_string()
+            };
+            println!(
+                "  {} [{}] → topic={}, tier={}",
+                style(&mem.key).white().bold(),
+                mem.category,
+                style(&topic).cyan(),
+                tier,
+            );
+            println!("    {}", style(&preview).dim());
+        }
+
+        return Ok(MigrationReport {
+            total_read: memories.len(),
+            migrated: 0,
+            skipped: memories.len(),
+            errors: vec![],
+        });
+    }
+
+    // Initialize Nomen for ingestion (no relay — local SurrealDB only).
+    let nomen_config = nomen::config::Config::default();
+    let nomen = nomen::Nomen::open(&nomen_config)
+        .await
+        .context("Failed to initialize Nomen for migration")?;
+
+    let mut report = MigrationReport {
+        total_read: memories.len(),
+        migrated: 0,
+        skipped: 0,
+        errors: vec![],
+    };
+
+    for mem in &memories {
+        let topic = normalize_topic(&mem.key);
+        let tier = category_to_nomen_tier(&mem.category);
+
+        // Check if already migrated (topic exists in Nomen).
+        match nomen.get_by_topic(&topic).await {
+            Ok(Some(_)) => {
+                report.skipped += 1;
+                continue;
+            }
+            Ok(None) => {}
+            Err(e) => {
+                report.errors.push(format!("{}: lookup failed: {e}", mem.key));
+                continue;
+            }
+        }
+
+        let new_mem = nomen::NewMemory {
+            topic: topic.clone(),
+            summary: first_line(&mem.content),
+            detail: mem.content.clone(),
+            tier: tier.to_string(),
+            confidence: 0.7,
+            source: Some("snowclaw-migrate".to_string()),
+            model: Some("snowclaw/legacy".to_string()),
+        };
+
+        match nomen.store(new_mem).await {
+            Ok(_) => {
+                report.migrated += 1;
+            }
+            Err(e) => {
+                report.errors.push(format!("{}: store failed: {e}", mem.key));
+            }
+        }
+    }
+
+    println!(
+        "\n{} Migration complete: {} migrated, {} skipped, {} errors.",
+        style("✓").green().bold(),
+        style(report.migrated).cyan().bold(),
+        report.skipped,
+        report.errors.len(),
+    );
+
+    if !report.errors.is_empty() {
+        println!("\nErrors:");
+        for err in &report.errors {
+            println!("  {} {}", style("✗").red(), err);
+        }
+    }
+
+    Ok(report)
+}
+
+/// Extract the first line of a string as a summary.
+fn first_line(s: &str) -> String {
+    s.lines()
+        .next()
+        .unwrap_or(s)
+        .chars()
+        .take(200)
+        .collect()
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn normalize_topic_strips_prefix() {
+        assert_eq!(normalize_topic("snowclaw:core:user-profile"), "user-profile");
+    }
+
+    #[test]
+    fn normalize_topic_handles_colons() {
+        assert_eq!(normalize_topic("my:nested:key"), "my-nested-key");
+    }
+
+    #[test]
+    fn normalize_topic_plain_key() {
+        assert_eq!(normalize_topic("simple-key"), "simple-key");
+    }
+
+    #[test]
+    fn normalize_topic_trims_hyphens() {
+        assert_eq!(normalize_topic("snowclaw::core:"), "core");
+        assert_eq!(normalize_topic("---key---"), "key");
+    }
+
+    #[test]
+    fn first_line_multiline() {
+        assert_eq!(first_line("hello\nworld"), "hello");
+    }
+
+    #[test]
+    fn first_line_single() {
+        assert_eq!(first_line("just one line"), "just one line");
+    }
+
+    #[test]
+    fn category_mapping() {
+        assert_eq!(category_to_nomen_tier("core"), "personal");
+        assert_eq!(category_to_nomen_tier("daily"), "personal");
+        assert_eq!(category_to_nomen_tier("conversation"), "personal");
+        assert_eq!(category_to_nomen_tier("custom_stuff"), "personal");
+    }
+}
