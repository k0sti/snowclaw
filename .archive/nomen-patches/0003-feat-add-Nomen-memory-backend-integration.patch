@@ -0,0 +1,203 @@
+//! Nomen memory backend adapter.
+//!
+//! Bridges Snowclaw's `Memory` trait to Nomen's SurrealDB-backed memory system,
+//! providing hybrid search (vector + BM25), Nostr relay sync, and consolidation.
+
+use async_trait::async_trait;
+use tokio::sync::OnceCell;
+
+use super::traits::{Memory, MemoryCategory, MemoryEntry};
+
+/// Adapter wrapping Nomen as a Snowclaw memory backend.
+pub struct NomenMemory {
+    config: nomen::config::Config,
+    nomen: OnceCell<nomen::Nomen>,
+}
+
+impl NomenMemory {
+    /// Create a new NomenMemory adapter.
+    ///
+    /// Initialization is lazy — the SurrealDB instance is created on first use.
+    pub fn new(config: nomen::config::Config) -> Self {
+        Self {
+            config,
+            nomen: OnceCell::new(),
+        }
+    }
+
+    /// Get or initialize the Nomen instance.
+    async fn nomen(&self) -> anyhow::Result<&nomen::Nomen> {
+        self.nomen
+            .get_or_try_init(|| async { nomen::Nomen::open(&self.config).await })
+            .await
+    }
+}
+
+/// Map a Snowclaw `MemoryCategory` to a Nomen tier string.
+fn category_to_tier(category: &MemoryCategory) -> String {
+    match category {
+        MemoryCategory::Core => "personal".to_string(),
+        MemoryCategory::Daily => "personal".to_string(),
+        MemoryCategory::Conversation => "personal".to_string(),
+        MemoryCategory::Custom(name) => name.clone(),
+    }
+}
+
+/// Map a Nomen tier string back to a Snowclaw `MemoryCategory`.
+fn tier_to_category(tier: &str) -> MemoryCategory {
+    match tier {
+        "personal" | "internal" => MemoryCategory::Core,
+        "shared" | "public" => MemoryCategory::Core,
+        other if other.starts_with("group:") => MemoryCategory::Custom(other.to_string()),
+        other => MemoryCategory::Custom(other.to_string()),
+    }
+}
+
+/// Convert a Nomen `SearchResult` to a Snowclaw `MemoryEntry`.
+fn search_result_to_entry(r: &nomen::search::SearchResult) -> MemoryEntry {
+    MemoryEntry {
+        id: r.d_tag.clone().unwrap_or_default(),
+        key: r.topic.clone(),
+        content: if r.detail.is_empty() {
+            r.summary.clone()
+        } else {
+            r.detail.clone()
+        },
+        category: tier_to_category(&r.tier),
+        timestamp: r.created_at.to_string(),
+        session_id: None,
+        score: Some(r.score),
+    }
+}
+
+/// Convert a Nomen `MemoryRecord` to a Snowclaw `MemoryEntry`.
+fn record_to_entry(r: &nomen::db::MemoryRecord) -> MemoryEntry {
+    MemoryEntry {
+        id: r.d_tag.clone().unwrap_or_default(),
+        key: r.topic.clone(),
+        content: r
+            .summary
+            .clone()
+            .unwrap_or_else(|| r.content.clone()),
+        category: tier_to_category(&r.tier),
+        timestamp: r.created_at.clone(),
+        session_id: None,
+        score: r.confidence,
+    }
+}
+
+#[async_trait]
+impl Memory for NomenMemory {
+    fn name(&self) -> &str {
+        "nomen"
+    }
+
+    async fn store(
+        &self,
+        key: &str,
+        content: &str,
+        category: MemoryCategory,
+        _session_id: Option<&str>,
+    ) -> anyhow::Result<()> {
+        let nomen = self.nomen().await?;
+        nomen
+            .store(nomen::NewMemory {
+                topic: key.to_string(),
+                summary: content.to_string(),
+                detail: content.to_string(),
+                tier: category_to_tier(&category),
+                confidence: 0.8,
+                source: Some("snowclaw".to_string()),
+                model: Some("snowclaw/agent".to_string()),
+            })
+            .await?;
+        Ok(())
+    }
+
+    async fn recall(
+        &self,
+        query: &str,
+        limit: usize,
+        _session_id: Option<&str>,
+    ) -> anyhow::Result<Vec<MemoryEntry>> {
+        let nomen = self.nomen().await?;
+        let results = nomen
+            .search(nomen::search::SearchOptions {
+                query: query.to_string(),
+                limit,
+                ..Default::default()
+            })
+            .await?;
+        Ok(results.iter().map(search_result_to_entry).collect())
+    }
+
+    async fn get(&self, key: &str) -> anyhow::Result<Option<MemoryEntry>> {
+        let nomen = self.nomen().await?;
+        let record = nomen.get_by_topic(key).await?;
+        Ok(record.as_ref().map(record_to_entry))
+    }
+
+    async fn list(
+        &self,
+        category: Option<&MemoryCategory>,
+        _session_id: Option<&str>,
+    ) -> anyhow::Result<Vec<MemoryEntry>> {
+        let nomen = self.nomen().await?;
+        let tier = category.map(category_to_tier);
+        let records = nomen
+            .list_memories(tier.as_deref(), 1000)
+            .await?;
+        Ok(records.iter().map(record_to_entry).collect())
+    }
+
+    async fn forget(&self, key: &str) -> anyhow::Result<bool> {
+        let nomen = self.nomen().await?;
+        // Check if memory exists before deleting.
+        let exists = nomen.get_by_topic(key).await?.is_some();
+        if exists {
+            nomen.delete(Some(key), None).await?;
+        }
+        Ok(exists)
+    }
+
+    async fn count(&self) -> anyhow::Result<usize> {
+        let nomen = self.nomen().await?;
+        let (total, _, _) = nomen.count_memories().await?;
+        Ok(total)
+    }
+
+    async fn health_check(&self) -> bool {
+        match self.nomen().await {
+            Ok(nomen) => nomen.count_memories().await.is_ok(),
+            Err(_) => false,
+        }
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn category_tier_roundtrip_core() {
+        let tier = category_to_tier(&MemoryCategory::Core);
+        assert_eq!(tier, "personal");
+        let cat = tier_to_category(&tier);
+        assert_eq!(cat, MemoryCategory::Core);
+    }
+
+    #[test]
+    fn category_tier_custom_preserves_value() {
+        let custom = MemoryCategory::Custom("group:engineering".into());
+        let tier = category_to_tier(&custom);
+        assert_eq!(tier, "group:engineering");
+        let cat = tier_to_category(&tier);
+        assert_eq!(cat, MemoryCategory::Custom("group:engineering".into()));
+    }
+
+    #[test]
+    fn nomen_memory_reports_correct_name() {
+        let mem = NomenMemory::new(nomen::config::Config::default());
+        assert_eq!(mem.name(), "nomen");
+    }
+}
