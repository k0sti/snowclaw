diff --git a/src/memory/nomen_signer.rs b/src/memory/nomen_signer.rs
new file mode 100644
index 00000000..65121db0
--- /dev/null
+++ b/src/memory/nomen_signer.rs
@@ -0,0 +1,28 @@
+//! Nomen signer bridge: builds a [`NomenSigner`] from Snowclaw's key config.
+//!
+//! Snowclaw stores nsec keys encrypted in config (ChaCha20-Poly1305) with env
+//! var fallback (`SNOWCLAW_NSEC`). This module bridges that to Nomen's signer
+//! trait using Nomen's built-in [`KeysSigner`], which uses nostr-sdk 0.39 types
+//! internally (matching Nomen's dependency).
+
+use std::sync::Arc;
+
+/// Build a [`nomen::signer::NomenSigner`] from an nsec string.
+///
+/// The nsec is parsed using Nomen's nostr-sdk 0.39 `Keys::parse()`, which
+/// accepts both `nsec1...` (Bech32) and hex formats.
+///
+/// Returns `None` if the nsec is empty or unparseable.
+pub fn build_signer(nsec: &str) -> Option<Arc<dyn nomen::signer::NomenSigner>> {
+    if nsec.trim().is_empty() {
+        return None;
+    }
+    // Delegate to Nomen's Config::build_signer() by constructing a minimal config.
+    // This ensures we use Nomen's nostr-sdk 0.39 types for key parsing, avoiding
+    // version mismatch with Snowclaw's nostr-sdk 0.44.
+    let config = nomen::config::Config {
+        nsec: Some(nsec.to_string()),
+        ..Default::default()
+    };
+    config.build_signer()
+}
